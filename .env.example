# ── Copier ce fichier en .env et remplir les valeurs ─────────
# cp .env.example .env

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=Tonde API
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000

# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tonde:tonde123@localhost:5432/tonde_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT — générer avec : openssl rand -hex 32 ────────────────
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OTP SMS (Africa's Talking) ────────────────────────────────
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=TONDE
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3

# ── Firebase FCM ──────────────────────────────────────────────
FIREBASE_SERVER_KEY=

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://10.0.2.2

# ── Migrations ────────────────────────────────────────────────
# true uniquement en développement, false en production
CREATE_TABLES_ON_STARTUP=false
